PORT=5000
MONGO_URI=
JWT_SECRET=
ADMIN_EMAILS=

# Email (recommended on Render)
RESEND_API_KEY=
RESEND_FROM=

# SMTP fallback (optional)
EMAIL_USER=
EMAIL_PASS=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_CONNECTION_TIMEOUT_MS=30000
EMAIL_GREETING_TIMEOUT_MS=30000
EMAIL_SOCKET_TIMEOUT_MS=30000

# Scanner APIs (optional)
OCR_SPACE_API_KEY=
BARCODE_LOOKUP_API_KEY=

# Cron controls
ENABLE_IN_PROCESS_CRON=false
EXPIRY_CRON_SCHEDULE=0 9 * * *
EXPIRY_CRON_TZ=Asia/Kolkata
